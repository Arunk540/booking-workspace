  "flows": [
    {
      "name": "temporal-activity-plan-task-queue-to-email-task-queue",
      "repo_chain": [
        "telikos-booking-service",
        "telikos-activityplanworkflow-service",
        "telikos-email-service"
      ],
      "topics": [
        {
          "topic": "TEMPORAL_ACTIVITY_PLAN_TASK_QUEUE",
          "protocol": "temporal-signal",
          "from": "telikos-booking-service",
          "to": "telikos-activityplanworkflow-service",
          "schema_path": "telikos-activityplanworkflow-service/common/src/main/resources/avro/ActivityPlanInternal.v2.avsc"
        },
        {
          "topic": "EMAIL_TASK_QUEUE",
          "protocol": "temporal-signal",
          "from": "telikos-activityplanworkflow-service",
          "to": "telikos-email-service",
          "schema_path": "telikos-activityplanworkflow-service/common/src/main/resources/avro/ActivityPlanInternal.v2.avsc"
        }
      ],
      "entry_files": {
        "telikos-booking-service": "runtime/rfp-flow.md",
        "telikos-activityplanworkflow-service": "runtime/rfp-tms-flow.md",
        "telikos-email-service": "runtime/booking-email-flow.md"
      },
      "triggers": [
        "booking confirmed email not sent",
        "email not received after booking",
        "booking to ap to email",
        "why did email not arrive",
        "confirm booking email flow",
        "rfp to email end to end",
        "booking confirmation email missing",
        "booking event no email",
        "tracing booking to email",
        "service plan email"
      ]
    },
    {
      "name": "temporal-activity-plan-task-queue-to-email-task-queue-invoice-dispatch",
      "repo_chain": [
        "telikos-booking-service",
        "telikos-activityplanworkflow-service",
        "telikos-email-service"
      ],
      "topics": [
        {
          "topic": "TEMPORAL_ACTIVITY_PLAN_TASK_QUEUE",
          "protocol": "temporal-signal",
          "from": "telikos-booking-service",
          "to": "telikos-activityplanworkflow-service",
          "schema_path": "telikos-activityplanworkflow-service/common/src/main/resources/avro/ActivityPlanInternal.v2.avsc"
        },
        {
          "topic": "EMAIL_TASK_QUEUE_INVOICE_DISPATCH",
          "protocol": "temporal-signal",
          "from": "telikos-activityplanworkflow-service",
          "to": "telikos-email-service",
          "schema_path": null
        }
      ],
      "entry_files": {
        "telikos-booking-service": "runtime/rfp-flow.md",
        "telikos-activityplanworkflow-service": "runtime/billing-flow.md",
        "telikos-email-service": "runtime/invoice-dispatch-flow.md"
      },
      "triggers": [
        "invoice email not received",
        "invoice dispatch failing",
        "billing invoice email",
        "invoice not sent to customer",
        "invoice dispatch email flow",
        "invoice email delivery issue",
        "why invoice email fails",
        "invoice dispatch not arriving",
        "billing to email invoice",
        "send invoice email"
      ]
    }
  ],
  "per_repo_summary": {
    "telikos-booking-service": "Owns inbound ServicePlan consumption from upstream, RFP/amend/cancel/pricing variant routing, and Temporal workflow start for all booking lifecycle events. Owns REST endpoints (/bookings, /transport-orders, /customs-orders) and SAP TMS/customs/VTS/CAMS feedback consumers. Does NOT own activity plan orchestration, email sending, or billing — those live in downstream services.",
    "telikos-activityplanworkflow-service": "Owns activity plan orchestration via Temporal workflows (V2 primary). Receives booking events via Temporal signals and dispatches tasks to email-service (activity calls), TMS (Kafka), customs (Kafka), and billing (Temporal). Only REST endpoint is GET /activity-plan/order/{id}. Does NOT own booking state or email delivery logic.",
    "telikos-email-service": "Owns email delivery via SendGrid for all booking lifecycle events, invoice dispatch, vendor notifications, and ad-hoc notifications. Receives work exclusively via Temporal activity calls from activityplanworkflow. Does NOT own booking state, activity plan orchestration, or billing."
  },
  "disambiguation_rules": [
    {
      "token": "tms",
      "default_repo": "telikos-booking-service",
      "rule": "SAP-TMS country routing, SEND_TO_TMS REST endpoint, SAP-TMS feedback consumer, TMS country validation live in booking-service-1. TMS Kafka producer (PublishTmsActivityImpl, TMS_TOPIC) lives in activityplanworkflow.",
      "AP_marker_phrases": [
        "publish to tms",
        "tms activity",
        "tms kafka",
        "send message to tms"
      ],
      "booking_marker_phrases": [
        "send to tms endpoint",
        "sap-tms feedback",
        "tms country routing",
        "tms eligible country"
      ]
    },
    {
      "token": "customs",
      "default_repo": "telikos-booking-service",
      "rule": "Customs response consumer (CustomsServiceOrderConsumer) and REST customs-status update live in booking-service-1. Customs request publisher (PublishMsgToCustomsActivityImpl, KAFKA_CUSTOMS_REQUEST_TOPIC) lives in activityplanworkflow.",
      "AP_marker_phrases": [
        "publish customs",
        "customs request",
        "send to customs activity",
        "customs kafka produce"
      ],
      "booking_marker_phrases": [
        "customs feedback",
        "customs status update",
        "customs response consumer"
      ]
    },
    {
      "token": "activity-plan",
      "default_repo": "telikos-activityplanworkflow-service",
      "rule": "ActivityPlan orchestration (workflow, activities, mongo collection) lives in activityplanworkflow. Booking-service-1 only dispatches TO the activity plan via Temporal — it does not own AP logic.",
      "AP_marker_phrases": [
        "activity plan workflow",
        "ap workflow fails",
        "activity plan mongo",
        "domain rules"
      ],
      "booking_marker_phrases": [
        "send service plan to ap",
        "booking dispatches to ap"
      ]
    }
  ]
}
